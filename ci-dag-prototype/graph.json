{
  "version": 1,
  "comment": "Mock build graph. Shaped to provoke the behaviors under test: a staggered diamond (liba slow, libb fast), a near-simultaneous diamond (eq1/eq2 equal duration -> duplicate-dispatch race), a 5-deep chain (workflow_run chain-depth validation), an independent 'noarch' root, and a finalize sink that aggregates everything.",
  "nodes": [
    { "id": "base",     "recipe_path": "recipes/base",     "target_platform": "linux-64", "variant": {}, "build_seconds": 15 },
    { "id": "liba",     "recipe_path": "recipes/liba",     "target_platform": "linux-64", "variant": {}, "build_seconds": 40 },
    { "id": "libb",     "recipe_path": "recipes/libb",     "target_platform": "linux-64", "variant": {}, "build_seconds": 5 },
    { "id": "app",      "recipe_path": "recipes/app",      "target_platform": "linux-64", "variant": {}, "build_seconds": 5 },
    { "id": "eq1",      "recipe_path": "recipes/eq1",      "target_platform": "linux-64", "variant": {}, "build_seconds": 20 },
    { "id": "eq2",      "recipe_path": "recipes/eq2",      "target_platform": "linux-64", "variant": {}, "build_seconds": 20 },
    { "id": "eqapp",    "recipe_path": "recipes/eqapp",    "target_platform": "linux-64", "variant": {}, "build_seconds": 5 },
    { "id": "c1",       "recipe_path": "recipes/c1",       "target_platform": "linux-64", "variant": {}, "build_seconds": 5 },
    { "id": "c2",       "recipe_path": "recipes/c2",       "target_platform": "linux-64", "variant": {}, "build_seconds": 5 },
    { "id": "c3",       "recipe_path": "recipes/c3",       "target_platform": "linux-64", "variant": {}, "build_seconds": 5 },
    { "id": "c4",       "recipe_path": "recipes/c4",       "target_platform": "linux-64", "variant": {}, "build_seconds": 5 },
    { "id": "c5",       "recipe_path": "recipes/c5",       "target_platform": "linux-64", "variant": {}, "build_seconds": 5 },
    { "id": "pytool",   "recipe_path": "recipes/pytool",   "target_platform": "noarch",   "variant": {}, "build_seconds": 5 },
    { "id": "finalize", "recipe_path": null,               "target_platform": null,       "variant": {}, "build_seconds": 3 }
  ],
  "edges": [
    { "from": "base", "to": "liba" },
    { "from": "base", "to": "libb" },
    { "from": "liba", "to": "app" },
    { "from": "libb", "to": "app" },

    { "from": "base", "to": "eq1" },
    { "from": "base", "to": "eq2" },
    { "from": "eq1",  "to": "eqapp" },
    { "from": "eq2",  "to": "eqapp" },

    { "from": "c1", "to": "c2" },
    { "from": "c2", "to": "c3" },
    { "from": "c3", "to": "c4" },
    { "from": "c4", "to": "c5" },

    { "from": "app",    "to": "finalize" },
    { "from": "eqapp",  "to": "finalize" },
    { "from": "c5",     "to": "finalize" },
    { "from": "pytool", "to": "finalize" }
  ]
}
